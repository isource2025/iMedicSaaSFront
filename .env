# 🌐 URL base del backend API
NEXT_PUBLIC_API_URL=http://localhost:5010/api

# 🔐 Clave para validar tokens o identificar cliente (si aplica en headers)
NEXT_PUBLIC_AUTH_CLIENT_ID=imedic-frontend

# 📦 Entorno de ejecución (development, staging, production)
NEXT_PUBLIC_APP_ENV=development

# 🧭 Título global o nombre de producto
NEXT_PUBLIC_APP_NAME=iMedic

# 🔄 Tiempo de expiración para token en ms (opcional)
NEXT_PUBLIC_TOKEN_EXPIRATION=3600000

# 🔗 URL para redireccionar tras login/logout
NEXT_PUBLIC_LOGIN_REDIRECT=/dashboard
NEXT_PUBLIC_LOGOUT_REDIRECT=/
